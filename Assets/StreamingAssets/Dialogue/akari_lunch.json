  "bondPointsOnComplete": 15,
  "lines": [
    { "speakerId": "akari", "text": "あ、詠くん！ お弁当、一緒に食べない？", "emotion": "smile", "preSilence": 0.0 },
    { "speakerId": "narrator", "text": "灯里は給食トレーを抱えて、教室の窓際の席を指さした。", "emotion": "neutral", "preSilence": 0.3 },
    { "speakerId": "akari", "text": "窓から港が見えるんだよ。霧の日でも、なんかいいでしょ？", "emotion": "smile", "preSilence": 0.3 },
    { "speakerId": "narrator", "text": "港は確かに霧の中にあった。灯台の光が、ぼんやりと光っている。", "emotion": "neutral", "preSilence": 0.6 }
  ],
  "choices": [
    {
      "afterLineIndex": 3,
