    { "speakerId": "narrator", "text": "図書室。律は窓際の席で、ノートPCを開いていた。", "emotion": "neutral", "preSilence": 0.5 },
    { "speakerId": "narrator", "text": "昼休みの喧騒が、扉の向こうに遠い。", "emotion": "neutral", "preSilence": 0.3 },
    { "speakerId": "ritsu", "text": "……また来た。", "emotion": "neutral", "preSilence": 0.5 },
    { "speakerId": "narrator", "text": "律はこちらを見ずに言った。でも、PCの画面は少し閉じた。", "emotion": "neutral", "preSilence": 0.4 },
    { "speakerId": "ritsu", "text": "うるさくしないなら、いてもいい。", "emotion": "neutral", "preSilence": 0.3 }
  ],
