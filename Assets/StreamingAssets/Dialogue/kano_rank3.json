{
  "id": "kano_rank3",
  "title": "残響の漏れ",
  "bondId": "kano",
  "bondPointsOnComplete": 95,
  "lines": [
    { "speakerId": "narrator", "text": "保健室。佳乃先生は窓際で書き物をしていた。静かな午後。", "emotion": "neutral", "preSilence": 0.4 },
    { "speakerId": "narrator", "text": "——〈残響同調〉が、制御できずに流れ込んできた。", "emotion": "neutral", "preSilence": 0.8 },
    { "speakerId": "narrator", "text": "「……ごめんなさい。産んであげられなくて。」", "emotion": "neutral", "preSilence": 1.0 },
    { "speakerId": "narrator", "text": "佳乃先生の声だった。でも佳乃先生は声に出していない。心の奥の、沈んだ言葉。", "emotion": "neutral", "preSilence": 0.8 },
    { "speakerId": "narrator", "text": "〈未読〉が震えた。聴いてはいけないものを聴いた。", "emotion": "neutral", "preSilence": 0.7 },
    { "speakerId": "kano", "text": "……聴こえたの？", "emotion": "flat", "preSilence": 0.5 },
    { "speakerId": "narrator", "text": "振り返らずに言った。気づかれていた。", "emotion": "neutral", "preSilence": 0.5 },
    { "speakerId": "kano", "text": "「残響」を持ってる子が転校してきたって、噂で聞いてたから。", "emotion": "neutral", "preSilence": 0.4 },
    { "speakerId": "kano", "text": "……驚かなかったの、自分でも。", "emotion": "flat", "preSilence": 0.5 }
  ],
  "choices": [
    {
      "afterLineIndex": 8,
      "options": [
        { "text": "ごめんなさい、勝手に", "requiredStat": "", "requiredRank": 0, "bondBonus": 30, "jumpToDialogueId": "" },
        { "text": "先生の気持ちを傷つけたかった訳じゃない", "requiredStat": "Expression", "requiredRank": 2, "bondBonus": 35, "jumpToDialogueId": "" },
        { "text": "（うつむく）", "requiredStat": "", "requiredRank": 0, "bondBonus": 20, "jumpToDialogueId": "" }
      ]
    }
  ],
  "postChoiceLines": [
    { "speakerId": "kano", "text": "……いいわ。あなたには、聞こえても。", "emotion": "soft", "preSilence": 0.7 },
    { "speakerId": "kano", "text": "不思議ね。怒れない。", "emotion": "flat", "preSilence": 0.5 },
    { "speakerId": "narrator", "text": "佳乃先生は書き物に戻った。それ以上は話さなかった。でも——拒絶ではなかった。", "emotion": "neutral", "preSilence": 0.7 },
    { "speakerId": "kano", "text": "今日は早く帰って。また来て。", "emotion": "soft", "preSilence": 0.5 },
    { "speakerId": "narrator", "text": "帰り際、消毒液の匂いの中に、薬草茶のにおいが混じっていた。", "emotion": "neutral", "preSilence": 0.8 }
  ]
}
